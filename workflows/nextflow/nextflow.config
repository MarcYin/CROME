manifest {
  name = 'crome-tile-batch'
  author = 'Marc Yin'
  description = 'Per-AlphaEarth-tile CROME labeling, model fitting, prediction, and pooled training.'
}

params {
  python = 'python'
  project_src = null
  batch_manifest = null
  run_pooled_model = true
  work_dir = null
  report_dir = '.nextflow-reports'

  executor_queue_size = 64
  slurm_account = null

  tile_partition = 'standard'
  tile_qos = 'high'
  tile_cpus = 16
  tile_memory = '128 GB'
  tile_time = '24h'

  pooled_partition = 'standard'
  pooled_qos = 'high'
  pooled_cpus = 48
  pooled_memory = '512 GB'
  pooled_time = '48h'

  pooled_output_dir = null
  max_train_rows = null
  n_estimators = null
  random_state = null
  test_size = null
}

workDir = params.work_dir ?: "${projectDir}/work"

timeline {
  enabled = true
  file = "${params.report_dir}/timeline.html"
}

report {
  enabled = true
  file = "${params.report_dir}/report.html"
}

trace {
  enabled = true
  file = "${params.report_dir}/trace.txt"
}

dag {
  enabled = true
  file = "${params.report_dir}/dag.html"
}

executor {
  queueSize = params.executor_queue_size as int
}

process {
  shell = ['/bin/bash', '-euo', 'pipefail']
  errorStrategy = 'terminate'
  stageInMode = 'rellink'

  withLabel: 'tile_baseline' {
    cpus = params.tile_cpus as int
    memory = params.tile_memory
    time = params.tile_time
  }

  withLabel: 'pooled_model' {
    cpus = params.pooled_cpus as int
    memory = params.pooled_memory
    time = params.pooled_time
  }
}

profiles {
  local {
    process.executor = 'local'

    process.withLabel: 'tile_baseline' {
      cpus = 2
      memory = '8 GB'
      time = '2h'
    }

    process.withLabel: 'pooled_model' {
      cpus = 4
      memory = '16 GB'
      time = '4h'
    }
  }

  jasmin {
    process.executor = 'slurm'

    process.withLabel: 'tile_baseline' {
      queue = params.tile_partition
      clusterOptions = params.slurm_account
        ? ["--qos=${params.tile_qos}", "--account=${params.slurm_account}"]
        : ["--qos=${params.tile_qos}"]
    }

    process.withLabel: 'pooled_model' {
      queue = params.pooled_partition
      clusterOptions = params.slurm_account
        ? ["--qos=${params.pooled_qos}", "--account=${params.slurm_account}"]
        : ["--qos=${params.pooled_qos}"]
    }
  }

  jasmin_debug {
    process.executor = 'slurm'

    process.withLabel: 'tile_baseline' {
      queue = 'debug'
      clusterOptions = ['--qos=debug']
      cpus = 4
      memory = '16 GB'
      time = '1h'
    }

    process.withLabel: 'pooled_model' {
      queue = 'debug'
      clusterOptions = ['--qos=debug']
      cpus = 4
      memory = '16 GB'
      time = '1h'
    }
  }

  jasmin_special {
    process.executor = 'slurm'

    process.withLabel: 'tile_baseline' {
      queue = params.tile_partition
      clusterOptions = params.slurm_account
        ? ["--qos=${params.tile_qos}", "--account=${params.slurm_account}"]
        : ["--qos=${params.tile_qos}"]
    }

    process.withLabel: 'pooled_model' {
      queue = 'special'
      clusterOptions = params.slurm_account
        ? ['--qos=special', "--account=${params.slurm_account}"]
        : ['--qos=special']
      cpus = 96
      memory = '3 TB'
      time = '48h'
    }
  }
}
