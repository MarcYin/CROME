def slurmOptions = { qos, extra ->
  [
    params.slurm_account ? "--account=${params.slurm_account}" : null,
    qos ? "--qos=${qos}" : null,
    extra,
  ].findAll { it }.join(' ')
}

params {
  python = 'python'
  project_src = null
  batch_manifest = null
  output_root = './outputs'
  work_dir = null

  test_size = 0.2
  random_state = 42
  n_estimators = 200
  max_train_rows = null
  tile_n_jobs = null
  pooled_n_jobs = null

  run_pooled_model = true
  pooled_output_dir = null

  slurm_account = null
  slurm_extra_options = null
  queue_size = 256
  tile_array_size = 128

  tile_partition = 'standard'
  tile_qos = 'high'
  tile_cpus = 16
  tile_memory = '128 GB'
  tile_time = '24h'

  pooled_partition = 'standard'
  pooled_qos = 'high'
  pooled_cpus = 64
  pooled_memory = '512 GB'
  pooled_time = '48h'
}

workDir = params.work_dir ?: "${params.output_root}/nextflow/work"

timeline {
  enabled = true
  file = "${params.output_root}/nextflow/reports/timeline.html"
}

report {
  enabled = true
  file = "${params.output_root}/nextflow/reports/report.html"
}

trace {
  enabled = true
  file = "${params.output_root}/nextflow/reports/trace.txt"
}

dag {
  enabled = true
  file = "${params.output_root}/nextflow/reports/dag.html"
}

process {
  executor = 'local'
  shell = ['/bin/bash', '-euo', 'pipefail']
  errorStrategy = { task.attempt <= 3 ? 'retry' : 'terminate' }
  maxRetries = 3
  cache = 'lenient'

  withLabel: download {
    cpus = 2
    memory = '8 GB'
    time = '48h'
  }

  withLabel: tile {
    cpus = params.tile_cpus as int
    memory = params.tile_memory
    time = params.tile_time
  }

  withLabel: pooled {
    cpus = params.pooled_cpus as int
    memory = params.pooled_memory
    time = params.pooled_time
  }
}

profiles {
  local {
    process.executor = 'local'
  }

  jasmin {
    process.executor = 'slurm'
    executor {
      queueSize = params.queue_size as int
      pollInterval = '15 sec'
      queueStatInterval = '1 min'
      submitRateLimit = '50/1min'
    }
    process {
      withLabel: download {
        queue = params.tile_partition
        clusterOptions = slurmOptions(params.tile_qos, params.slurm_extra_options)
        cpus = 2
        memory = '8 GB'
        time = '12h'
      }
      withLabel: tile {
        queue = params.tile_partition
        clusterOptions = slurmOptions(params.tile_qos, params.slurm_extra_options)
        if (params.tile_array_size != null) {
          array = params.tile_array_size as int
        }
      }
      withLabel: pooled {
        queue = params.pooled_partition
        clusterOptions = slurmOptions(params.pooled_qos, params.slurm_extra_options)
      }
    }
  }

  jasmin_special {
    process.executor = 'slurm'
    executor {
      queueSize = params.queue_size as int
      pollInterval = '15 sec'
      queueStatInterval = '1 min'
      submitRateLimit = '50/1min'
    }
    process {
      withLabel: download {
        queue = params.tile_partition
        clusterOptions = slurmOptions(params.tile_qos, params.slurm_extra_options)
        cpus = 2
        memory = '8 GB'
        time = '12h'
      }
      withLabel: tile {
        queue = params.tile_partition
        clusterOptions = slurmOptions(params.tile_qos, params.slurm_extra_options)
        if (params.tile_array_size != null) {
          array = params.tile_array_size as int
        }
      }
      withLabel: pooled {
        queue = 'special'
        cpus = 96
        memory = '1500 GB'
        time = '48h'
        clusterOptions = slurmOptions('special', params.slurm_extra_options)
      }
    }
  }
}
