def slurmOptions = { qos, extra ->
  [
    params.slurm_account ? "--account=${params.slurm_account}" : null,
    qos ? "--qos=${qos}" : null,
    extra,
  ].findAll { it }.join(' ')
}

params {
  python = 'python'
  manifest_path = null
  feature_input = null
  reference_path = null
  output_root = './outputs'
  work_dir = null

  year = null
  run_label = 'alphaearth'

  label_column = 'lucode'
  geometry_column = 'geometry'
  label_mode = 'centroid_to_pixel'
  overlap_policy = 'first'
  all_touched = false
  nodata_label = -1

  test_size = 0.2
  random_state = 42
  n_estimators = 200
  max_train_rows = null
  tile_n_jobs = null
  pooled_n_jobs = null

  no_predict = false
  fail_on_empty_labels = false
  run_pooled_model = true
  pooled_output_dir = null

  slurm_account = null
  slurm_extra_options = null
  queue_size = 256

  control_partition = 'debug'
  control_qos = 'debug'
  control_cpus = 1
  control_memory = '4 GB'
  control_time = '1h'

  tile_partition = 'standard'
  tile_qos = 'high'
  tile_cpus = 16
  tile_memory = '128 GB'
  tile_time = '24h'

  pooled_partition = 'standard'
  pooled_qos = 'high'
  pooled_cpus = 64
  pooled_memory = '512 GB'
  pooled_time = '48h'
}

workDir = params.work_dir ?: "${params.output_root}/nextflow/work"

timeline {
  enabled = true
  file = "${params.output_root}/nextflow/reports/timeline.html"
}

report {
  enabled = true
  file = "${params.output_root}/nextflow/reports/report.html"
}

trace {
  enabled = true
  file = "${params.output_root}/nextflow/reports/trace.txt"
}

dag {
  enabled = true
  file = "${params.output_root}/nextflow/reports/dag.html"
}

process {
  executor = 'local'
  shell = ['/bin/bash', '-euo', 'pipefail']
  errorStrategy = 'terminate'

  withLabel: control {
    cpus = params.control_cpus as int
    memory = params.control_memory
    time = params.control_time
  }

  withLabel: tile {
    cpus = params.tile_cpus as int
    memory = params.tile_memory
    time = params.tile_time
  }

  withLabel: pooled {
    cpus = params.pooled_cpus as int
    memory = params.pooled_memory
    time = params.pooled_time
  }
}

profiles {
  local {
    process.executor = 'local'
  }

  jasmin {
    process.executor = 'slurm'
    executor {
      queueSize = params.queue_size as int
      pollInterval = '15 sec'
      queueStatInterval = '1 min'
      submitRateLimit = '50/1min'
    }
    process {
      withLabel: control {
        queue = params.control_partition
        clusterOptions = slurmOptions(params.control_qos, params.slurm_extra_options)
      }
      withLabel: tile {
        queue = params.tile_partition
        clusterOptions = slurmOptions(params.tile_qos, params.slurm_extra_options)
      }
      withLabel: pooled {
        queue = params.pooled_partition
        clusterOptions = slurmOptions(params.pooled_qos, params.slurm_extra_options)
      }
    }
  }

  jasmin_special {
    process.executor = 'slurm'
    executor {
      queueSize = params.queue_size as int
      pollInterval = '15 sec'
      queueStatInterval = '1 min'
      submitRateLimit = '50/1min'
    }
    process {
      withLabel: control {
        queue = params.control_partition
        clusterOptions = slurmOptions(params.control_qos, params.slurm_extra_options)
      }
      withLabel: tile {
        queue = params.tile_partition
        clusterOptions = slurmOptions(params.tile_qos, params.slurm_extra_options)
      }
      withLabel: pooled {
        queue = 'special'
        cpus = 96
        memory = '1500 GB'
        time = '48h'
        clusterOptions = slurmOptions('special', params.slurm_extra_options)
      }
    }
  }
}
